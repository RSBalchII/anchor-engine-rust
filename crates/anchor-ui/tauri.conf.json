{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anchor UI",
  "version": "0.1.0",
  "identifier": "com.anchor-os.ui",
  "build": {
    "frontendDist": "../assets",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Anchor - Sovereign Knowledge Engine",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  },
  "plugins": {
    "http": {
      "enabled": true,
      "scope": ["http://localhost:*", "https://localhost:*"]
    }
  }
}
